{
  "expo": {
    "name": "SmartDukaan",
    "slug": "small-vendor-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "smartdukaan",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080B14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.prakharrm.smallvendorclient",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-status-bar",

      [
        "expo-image-picker",
        {
          "photosPermission": "SmartDukaan needs access to your photos to upload product images.",
          "cameraPermission": "SmartDukaan needs access to your camera to scan products."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}